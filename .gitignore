# =============================
# Course-Selling Application
# Monorepo .gitignore
# =============================


# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
secrets/

# Per-workspace env files
Backend/.env
Backend/.env.*
!Backend/.env.example
Frontend/.env
Frontend/.env.*
!Frontend/.env.example


# ─── Node / Dependencies ─────────────────────────────────────────────────────
node_modules/
Backend/node_modules/
Frontend/node_modules/


# ─── Frontend: Vite / React Build Output ─────────────────────────────────────
Frontend/dist/
Frontend/build/
Frontend/.vite/
Frontend/.cache/
Frontend/coverage/


# ─── Backend: Build & Compiled Output ────────────────────────────────────────
Backend/dist/
Backend/build/


# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
Backend/logs/
Backend/error.log
Backend/combined.log


# ─── Database ────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
dump.rdb
Backend/data/
mongo-data/


# ─── Payment & API Credentials ───────────────────────────────────────────────
stripe-webhook-secret.txt
paypal-config.*
razorpay-config.*
payment-keys.*


# ─── Media & User Uploads ────────────────────────────────────────────────────
Backend/uploads/
Backend/storage/
Backend/media/
*.mp4
*.mov
*.avi
*.mkv
*.webm
raw-assets/
course-videos/
course-drafts/


# ─── Testing & Coverage ──────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
Frontend/cypress/videos/
Frontend/cypress/screenshots/
junit.xml


# ─── Docker ──────────────────────────────────────────────────────────────────
docker-compose.override.yml
*.env.docker


# ─── Cloud & Deployment ──────────────────────────────────────────────────────
.vercel/
.netlify/
.serverless/
.amplify/
terraform.tfstate
terraform.tfstate.backup
*.tfvars
!example.tfvars
.terraform/


# ─── Cache ───────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.sass-cache/
*.tsbuildinfo


# ─── OS Artifacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# ─── Editor ──────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.iml
*.iws
*.swp
*.swo
*~


# ─── Misc ────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
notes.private.*
